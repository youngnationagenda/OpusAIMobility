{
  "name": "@opusaimobility/common",
  "version": "1.0.0",
  "description": "Shared utilities, constants, and types for OpusAIMobility platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js"
    },
    "./device-tokens": {
      "types": "./dist/device-tokens.d.ts",
      "import": "./dist/device-tokens.js"
    },
    "./file-retrieval": {
      "types": "./dist/file-retrieval.d.ts",
      "import": "./dist/file-retrieval.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "src"
  ]
}
