{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerReadForBuild",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:683541453923:secret:opusaimobility/*",
        "arn:aws:secretsmanager:us-east-1:683541453923:secret:terraai/*",
        "arn:aws:secretsmanager:us-east-1:683541453923:secret:omniride/*"
      ]
    },
    {
      "Sid": "S3APKBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObjectAcl",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-apk-distribution",
        "arn:aws:s3:::opusaimobility-apk-distribution/*"
      ]
    },
    {
      "Sid": "LambdaUpdateCode",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:PublishVersion"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:683541453923:function:terraaimobility-*",
        "arn:aws:lambda:us-east-1:683541453923:function:aimobility-*"
      ]
    },
    {
      "Sid": "S3FrontendBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:DeleteObject",
        "s3:PutObjectAcl"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-assets-prod",
        "arn:aws:s3:::opusaimobility-assets-prod/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidation",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetDistribution",
        "cloudfront:GetInvalidation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CodeBuildLogsAndArtifacts",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:683541453923:log-group:/aws/codebuild/*"
    },
    {
      "Sid": "CodeBuildArtifactsBucket",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketAcl",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-codebuild-artifacts-683541453923",
        "arn:aws:s3:::opusaimobility-codebuild-artifacts-683541453923/*"
      ]
    }
  ]
}
