{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCodeBuildPut",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::683541453923:role/OpusAIMobility-CodeBuild-Role"
      },
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:PutObjectAcl",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-apk-distribution",
        "arn:aws:s3:::opusaimobility-apk-distribution/*"
      ]
    },
    {
      "Sid": "AllowPublicDownload",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::opusaimobility-apk-distribution/*"
    }
  ]
}
