{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaDeploy",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:PublishVersion",
        "lambda:CreateAlias",
        "lambda:UpdateAlias",
        "lambda:GetAlias",
        "lambda:ListVersionsByFunction",
        "lambda:TagResource",
        "lambda:ListTags"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:683541453923:function:opusaimobility-api",
        "arn:aws:lambda:us-east-1:683541453923:function:opusaimobility-push-notification",
        "arn:aws:lambda:us-east-1:683541453923:function:opusaimobility-celo-deploy",
        "arn:aws:lambda:us-east-1:683541453923:function:opusaimobility-*"
      ]
    },
    {
      "Sid": "S3FrontendDeploy",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:PutObjectAcl"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-assets-prod",
        "arn:aws:s3:::opusaimobility-assets-prod/*",
        "arn:aws:s3:::omniride-assets-prod",
        "arn:aws:s3:::omniride-assets-prod/*"
      ]
    },
    {
      "Sid": "S3APKDistribution",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:CopyObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::opusaimobility-assets-prod/apks/*",
        "arn:aws:s3:::opusaimobility-assets-prod/lambda-deploys/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidate",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation",
        "cloudfront:ListDistributions"
      ],
      "Resource": [
        "arn:aws:cloudfront::683541453923:distribution/E1TIJJKJ2UEIO7",
        "arn:aws:cloudfront::683541453923:distribution/E18GJ5VKHBIJAI"
      ]
    },
    {
      "Sid": "ECRAccess",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken",
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability",
        "ecr:PutImage",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:DescribeRepositories",
        "ecr:CreateRepository",
        "ecr:DescribeImages"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECSDeployAccess",
      "Effect": "Allow",
      "Action": [
        "ecs:UpdateService",
        "ecs:DescribeServices",
        "ecs:DescribeClusters",
        "ecs:RegisterTaskDefinition",
        "ecs:DescribeTaskDefinition",
        "ecs:ListTaskDefinitions",
        "ecs:TagResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IAMPassRoleForECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::683541453923:role/opusaimobility-*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    },
    {
      "Sid": "SecretsReadOnly",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:683541453923:secret:opusaimobility/*"
    },
    {
      "Sid": "CodeConnectionsUse",
      "Effect": "Allow",
      "Action": [
        "codeconnections:UseConnection",
        "codeconnections:GetConnection",
        "codestar-connections:UseConnection",
        "codestar-connections:GetConnection"
      ],
      "Resource": "arn:aws:codeconnections:us-east-1:683541453923:connection/106cbfc4-0ec6-492a-bf08-43ba86575ea1"
    },
    {
      "Sid": "AmazonQReview",
      "Effect": "Allow",
      "Action": [
        "q:StartConversation",
        "q:SendMessage",
        "q:GetConversation",
        "q:StartCodeReview",
        "q:GetCodeReview",
        "q:ListCodeReviews",
        "q:CreateAssignment",
        "q:GetAssignment",
        "q:ListAssignments",
        "q:UpdateAssignment"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:us-east-1:683541453923:log-group:/opusaimobility/*"
    }
  ]
}
