{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "iot:Publish",
        "iot:Connect"
      ],
      "Resource": [
        "arn:aws:iot:us-east-1:683541453923:topic/opusaimobility/notifications/*",
        "arn:aws:iot:us-east-1:683541453923:client/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "mobiletargeting:PutEvents",
        "mobiletargeting:GetEndpoint",
        "mobiletargeting:UpdateEndpoint"
      ],
      "Resource": "arn:aws:mobiletargeting:us-east-1:683541453923:apps/20d7e36cc4094a04b63b7fd1e5596fcf/*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:683541453923:*"
    }
  ]
}
