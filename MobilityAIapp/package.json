{
  "name": "opusaimobility-zero-emission-mobility",
  "private": true,
  "version": "1.0.0",
  "description": "OpusAIMobility: 100% Zero-Emission Mobility Platform — AI-powered ride-hailing aggregating electric-only services with carbon tracking, blockchain, DeFi and AWS backend.",
  "type": "module",
  "workspaces": [
    "shared",
    "scripts/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "type:check": "tsc --noEmit",
    "server:check": "node scripts/ci/server-check.cjs",
    "server": "npm run server:check && node server/server.js",
    "server:dev": "npm run server:check && nodemon server/server.js",
    "server:unsafe": "node server/server.js",
    "deploy": "node backend/lambda/deploy-frontend.cjs",
    "deploy:restart": "node backend/lambda/deploy-frontend.cjs --restart-server"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "fast-check": "^4.8.0",
    "mysql2": "^3.22.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.10"
  }
}
