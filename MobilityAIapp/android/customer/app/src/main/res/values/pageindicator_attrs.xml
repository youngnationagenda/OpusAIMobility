<?xml version="1.0" encoding="utf-8"?>
<!-- CircleIndicator (me.relex:circleindicator:2.1.6) custom attrs
     These are declared in the library's own attrs.xml but need to be
     available here to prevent AAPT2 "attribute not found" errors.
     Library on Maven Central — no JitPack needed. -->
<resources>
    <declare-styleable name="CircleIndicator">
        <attr name="ci_drawable" format="reference"/>
        <attr name="ci_drawable_unselected" format="reference"/>
        <attr name="ci_height" format="dimension"/>
        <attr name="ci_width" format="dimension"/>
        <attr name="ci_margin" format="dimension"/>
        <attr name="ci_radius" format="dimension"/>
        <attr name="ci_orientation" format="enum">
            <enum name="horizontal" value="0"/>
            <enum name="vertical" value="1"/>
        </attr>
        <attr name="ci_gravity" format="integer"/>
        <attr name="ci_animateOnClick" format="boolean"/>
        <attr name="ci_animator" format="reference"/>
        <attr name="ci_animator_reverse" format="reference"/>
        <attr name="ci_selectedColor" format="color"/>
        <attr name="ci_unselectedColor" format="color"/>
        <!-- pageindicator compat alias -->
        <attr name="ci_drawable_unselected_color" format="color"/>
    </declare-styleable>
</resources>
