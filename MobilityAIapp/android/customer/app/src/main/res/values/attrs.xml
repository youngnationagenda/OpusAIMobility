<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="AnchorBottomSheetBehavior_Layout">
        <attr name="behavior_anchorOffset" format="dimension" />
        <attr name="behavior_defaultState" format="enum">
            <enum name="expanded" value="3" />
            <enum name="collapsed" value="4" />
            <enum name="hidden" value="5" />
            <enum name="anchored" value="6" />
        </attr>
        <attr name="behavior_skipAnchored" format="boolean" />
    </declare-styleable>


    <declare-styleable name="LoadingButton">
        <attr name="text" format="string" localization="suggested" />
        <attr name="textColor" format="color" />
        <attr name="backgroundColor" format="color"/>
        <attr name="background" format="reference"/>
        <attr name="textSize" format="dimension"/>
        <attr name="progressColor" format="color"/>
    </declare-styleable>

    <declare-styleable name="SingleDateAndTimePicker">
        <attr name="picker_curved" format="boolean" />
        <attr name="picker_cyclic" format="boolean" />
        <attr name="picker_textColor" format="color" />
        <attr name="picker_selectedTextColor" format="color" />
        <attr name="picker_selectorColor" format="color" />
        <attr name="picker_textSize" format="dimension" />
        <attr name="picker_visibleItemCount" format="integer" />
        <attr name="picker_itemSpacing" format="dimension" />
        <attr name="picker_displayHours" format="boolean" />
        <attr name="picker_displayMinutes" format="boolean" />
        <attr name="picker_displayDays" format="boolean" />
        <attr name="picker_displayMonth" format="boolean" />
        <attr name="picker_displayYears" format="boolean" />
        <attr name="picker_displayDaysOfMonth" format="boolean" />
        <attr name="picker_displayMonthNumbers" format="boolean" />
        <attr name="picker_mustBeOnFuture" format="boolean" />
        <attr name="picker_dayCount" format="integer" />
        <attr name="picker_stepSizeMinutes" format="integer" />
        <attr name="picker_stepSizeHours" format="integer" />
    </declare-styleable>

</resources>
