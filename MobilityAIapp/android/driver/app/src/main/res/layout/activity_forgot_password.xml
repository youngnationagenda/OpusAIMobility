<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="@dimen/spacing_lg"
    android:background="@color/colorBackground">
    <ImageView android:id="@+id/ivBack" android:layout_width="@dimen/icon_size"
        android:layout_height="@dimen/icon_size" android:src="@drawable/ic_back"
        android:contentDescription="Back" android:layout_marginTop="@dimen/spacing_md"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Forgot Password" android:textSize="24sp"
        android:textColor="@color/colorTextPrimary" android:fontFamily="@font/poppins_bold"
        android:layout_marginTop="@dimen/spacing_lg"/>
    <com.google.android.material.textfield.TextInputLayout style="@style/TextInputDriver"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl" android:hint="@string/email_hint">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textEmailAddress"/>
    </com.google.android.material.textfield.TextInputLayout>
    <ProgressBar android:id="@+id/progressBar" android:layout_width="40dp"
        android:layout_height="40dp" android:layout_gravity="center"
        android:layout_marginTop="@dimen/spacing_md" android:visibility="gone"
        android:indeterminateTint="@color/colorPrimary"/>
    <com.google.android.material.button.MaterialButton android:id="@+id/btnSendReset"
        style="@style/ButtonPrimary" android:layout_width="match_parent"
        android:layout_height="56dp" android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/btn_send_reset"/>
</LinearLayout>
