<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Map fills the full screen -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top status bar overlay -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:background="@color/colorSurface">

            <!-- Driver avatar -->
            <ImageView
                android:id="@+id/ivDriverAvatar"
                android:layout_width="@dimen/avatar_size_sm"
                android:layout_height="@dimen/avatar_size_sm"
                android:src="@drawable/ic_driver_avatar"
                android:contentDescription="Driver" />

            <!-- Driver info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvDriverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/colorTextPrimary"
                    android:fontFamily="@font/poppins_semibold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_offline" />

                    <TextView
                        android:id="@+id/tvOnlineStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/status_offline"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/colorOffline"
                        android:fontFamily="@font/poppins_medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0 ★"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/colorWarning" />
                </LinearLayout>
            </LinearLayout>

            <!-- Online toggle -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchOnline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/white"
                android:trackTint="@color/colorPrimaryLight"
                app:trackTintMode="src_atop" />

            <!-- Notifications -->
            <ImageView
                android:id="@+id/ivNotifications"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_notification"
                android:contentDescription="Notifications" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Earnings card (bottom overlay) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/spacing_md"
        android:layout_marginBottom="80dp"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:background="@color/colorSurface">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_earnings"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/colorTextSecondary" />
                <TextView
                    android:id="@+id/tvTodayEarnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KSh 0.00"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/colorDivider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_trips"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/colorTextSecondary" />
                <TextView
                    android:id="@+id/tvTodayTrips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 trips"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/colorTextPrimary"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:background="@color/colorSurface"
        app:menu="@menu/driver_bottom_nav"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
