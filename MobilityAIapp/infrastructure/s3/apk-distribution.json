{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "S3 bucket and CloudFront distribution for APK artifact storage and distribution",
  "Resources": {
    "ApkDistributionBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "opusaimobility-apk-distribution",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "RetainOnly10DebugAPKs",
              "Status": "Enabled",
              "Prefix": "apks/customer/debug/",
              "NoncurrentVersionExpiration": {
                "NoncurrentDays": 1,
                "NewerNoncurrentVersions": 10
              },
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 1
              }
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "OpusAIMobility"
          },
          {
            "Key": "Component",
            "Value": "APK-Distribution"
          }
        ]
      }
    },
    "ApkBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": { "Ref": "ApkDistributionBucket" },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowCloudFrontOAC",
              "Effect": "Allow",
              "Principal": {
                "Service": "cloudfront.amazonaws.com"
              },
              "Action": "s3:GetObject",
              "Resource": {
                "Fn::Sub": "arn:aws:s3:::${ApkDistributionBucket}/apks/*"
              },
              "Condition": {
                "StringEquals": {
                  "AWS:SourceArn": {
                    "Fn::Sub": "arn:aws:cloudfront::${AWS::AccountId}:distribution/${ApkCloudFrontDistribution}"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "ApkOriginAccessControl": {
      "Type": "AWS::CloudFront::OriginAccessControl",
      "Properties": {
        "OriginAccessControlConfig": {
          "Name": "opusaimobility-apk-oac",
          "Description": "OAC for APK distribution bucket",
          "OriginAccessControlOriginType": "s3",
          "SigningBehavior": "always",
          "SigningProtocol": "sigv4"
        }
      }
    },
    "ApkCachePolicyLatest": {
      "Type": "AWS::CloudFront::CachePolicy",
      "Properties": {
        "CachePolicyConfig": {
          "Name": "opusaimobility-apk-latest-cache-policy",
          "Comment": "Short TTL cache policy for latest.apk (5 minutes)",
          "DefaultTTL": 300,
          "MaxTTL": 300,
          "MinTTL": 0,
          "ParametersInCacheKeyAndForwardedToOrigin": {
            "CookiesConfig": {
              "CookieBehavior": "none"
            },
            "HeadersConfig": {
              "HeaderBehavior": "none"
            },
            "QueryStringsConfig": {
              "QueryStringBehavior": "none"
            },
            "EnableAcceptEncodingGzip": false,
            "EnableAcceptEncodingBrotli": false
          }
        }
      }
    },
    "ApkCachePolicyVersioned": {
      "Type": "AWS::CloudFront::CachePolicy",
      "Properties": {
        "CachePolicyConfig": {
          "Name": "opusaimobility-apk-versioned-cache-policy",
          "Comment": "Long TTL cache policy for versioned APKs (1 year)",
          "DefaultTTL": 31536000,
          "MaxTTL": 31536000,
          "MinTTL": 31536000,
          "ParametersInCacheKeyAndForwardedToOrigin": {
            "CookiesConfig": {
              "CookieBehavior": "none"
            },
            "HeadersConfig": {
              "HeaderBehavior": "none"
            },
            "QueryStringsConfig": {
              "QueryStringBehavior": "none"
            },
            "EnableAcceptEncodingGzip": false,
            "EnableAcceptEncodingBrotli": false
          }
        }
      }
    },
    "ApkResponseHeadersPolicy": {
      "Type": "AWS::CloudFront::ResponseHeadersPolicy",
      "Properties": {
        "ResponseHeadersPolicyConfig": {
          "Name": "opusaimobility-apk-response-headers",
          "Comment": "Response headers for APK downloads with correct content-type and disposition",
          "CustomHeadersConfig": {
            "Items": [
              {
                "Header": "Content-Type",
                "Value": "application/vnd.android.package-archive",
                "Override": true
              },
              {
                "Header": "Content-Disposition",
                "Value": "attachment; filename=\"app.apk\"",
                "Override": false
              }
            ]
          }
        }
      }
    },
    "ApkCloudFrontDistribution": {
      "Type": "AWS::CloudFront::Distribution",
      "Properties": {
        "DistributionConfig": {
          "Comment": "OpusAIMobility APK Distribution",
          "Enabled": true,
          "HttpVersion": "http2",
          "IsIPV6Enabled": true,
          "PriceClass": "PriceClass_All",
          "DefaultRootObject": "",
          "Origins": [
            {
              "Id": "apk-s3-origin",
              "DomainName": {
                "Fn::GetAtt": ["ApkDistributionBucket", "RegionalDomainName"]
              },
              "OriginAccessControlId": { "Ref": "ApkOriginAccessControl" },
              "S3OriginConfig": {
                "OriginAccessIdentity": ""
              }
            }
          ],
          "DefaultCacheBehavior": {
            "TargetOriginId": "apk-s3-origin",
            "ViewerProtocolPolicy": "redirect-to-https",
            "AllowedMethods": ["HEAD", "GET"],
            "CachedMethods": ["HEAD", "GET"],
            "CachePolicyId": { "Ref": "ApkCachePolicyVersioned" },
            "ResponseHeadersPolicyId": { "Ref": "ApkResponseHeadersPolicy" },
            "Compress": false
          },
          "CacheBehaviors": [
            {
              "PathPattern": "/apks/customer/debug/latest.apk",
              "TargetOriginId": "apk-s3-origin",
              "ViewerProtocolPolicy": "redirect-to-https",
              "AllowedMethods": ["HEAD", "GET"],
              "CachedMethods": ["HEAD", "GET"],
              "CachePolicyId": { "Ref": "ApkCachePolicyLatest" },
              "ResponseHeadersPolicyId": { "Ref": "ApkResponseHeadersPolicy" },
              "Compress": false
            },
            {
              "PathPattern": "/apks/*",
              "TargetOriginId": "apk-s3-origin",
              "ViewerProtocolPolicy": "redirect-to-https",
              "AllowedMethods": ["HEAD", "GET"],
              "CachedMethods": ["HEAD", "GET"],
              "CachePolicyId": { "Ref": "ApkCachePolicyVersioned" },
              "ResponseHeadersPolicyId": { "Ref": "ApkResponseHeadersPolicy" },
              "Compress": false
            }
          ],
          "ViewerCertificate": {
            "CloudFrontDefaultCertificate": true
          }
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "OpusAIMobility"
          },
          {
            "Key": "Component",
            "Value": "APK-Distribution"
          }
        ]
      }
    }
  },
  "Outputs": {
    "BucketName": {
      "Description": "Name of the APK distribution bucket",
      "Value": { "Ref": "ApkDistributionBucket" }
    },
    "BucketArn": {
      "Description": "ARN of the APK distribution bucket",
      "Value": { "Fn::GetAtt": ["ApkDistributionBucket", "Arn"] }
    },
    "DistributionId": {
      "Description": "CloudFront distribution ID for APK delivery",
      "Value": { "Ref": "ApkCloudFrontDistribution" }
    },
    "DistributionDomainName": {
      "Description": "CloudFront domain name for APK downloads",
      "Value": { "Fn::GetAtt": ["ApkCloudFrontDistribution", "DomainName"] }
    },
    "LatestApkUrl": {
      "Description": "Stable URL for latest debug APK",
      "Value": {
        "Fn::Sub": "https://${ApkCloudFrontDistribution.DomainName}/apks/customer/debug/latest.apk"
      }
    }
  }
}
