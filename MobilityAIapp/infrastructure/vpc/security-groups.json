{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "OpusAIMobility VPC Security Groups",
  "Parameters": {
    "VpcId": {
      "Type": "AWS::EC2::VPC::Id",
      "Description": "VPC ID to create security groups in"
    }
  },
  "Resources": {
    "AlbSG": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": "opusaimobility-alb-sg",
        "GroupDescription": "Security group for Application Load Balancer",
        "VpcId": { "Ref": "VpcId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTP from internet"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS from internet"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "DestinationSecurityGroupId": { "Ref": "TerraApiSG" },
            "Description": "HTTP to ECS tasks"
          }
        ],
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-alb-sg" }]
      }
    },
    "TerraApiSG": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": "opusaimobility-terraapi-sg",
        "GroupDescription": "Security group for TerraAI PHP API ECS Fargate tasks",
        "VpcId": { "Ref": "VpcId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "SourceSecurityGroupId": { "Ref": "AlbSG" },
            "Description": "HTTP from ALB only"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "SourceSecurityGroupId": { "Ref": "AlbSG" },
            "Description": "HTTPS from ALB only"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow all outbound (for AWS SDK calls)"
          }
        ],
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-terraapi-sg" }]
      }
    },
    "RdsSG": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": "opusaimobility-rds-sg",
        "GroupDescription": "Security group for RDS MySQL — inbound from ECS only",
        "VpcId": { "Ref": "VpcId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": { "Ref": "TerraApiSG" },
            "Description": "MySQL from TerraAI ECS tasks only"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": { "Ref": "LambdaSG" },
            "Description": "MySQL from Lambda (VPC mode) only"
          }
        ],
        "SecurityGroupEgress": [],
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-rds-sg" }]
      }
    },
    "LambdaSG": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": "opusaimobility-lambda-sg",
        "GroupDescription": "Security group for Lambda functions running in VPC",
        "VpcId": { "Ref": "VpcId" },
        "SecurityGroupIngress": [],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "DestinationSecurityGroupId": { "Ref": "RdsSG" },
            "Description": "MySQL to RDS"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS outbound for AWS service calls"
          }
        ],
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-lambda-sg" }]
      }
    }
  },
  "Outputs": {
    "AlbSGId": { "Value": { "Ref": "AlbSG" }, "Export": { "Name": "OpusAIMobility-AlbSGId" } },
    "TerraApiSGId": { "Value": { "Ref": "TerraApiSG" }, "Export": { "Name": "OpusAIMobility-TerraApiSGId" } },
    "RdsSGId": { "Value": { "Ref": "RdsSG" }, "Export": { "Name": "OpusAIMobility-RdsSGId" } },
    "LambdaSGId": { "Value": { "Ref": "LambdaSG" }, "Export": { "Name": "OpusAIMobility-LambdaSGId" } }
  }
}
