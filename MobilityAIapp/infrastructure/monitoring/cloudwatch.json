{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "OpusAIMobility CloudWatch Alarms and Dashboard",
  "Parameters": {
    "SnsTopicArn": {
      "Type": "String",
      "Default": "arn:aws:sns:us-east-1:683541453923:omniride-notifications"
    },
    "LambdaFunctionName": {
      "Type": "String",
      "Default": "omniride-api"
    },
    "ApiGatewayId": {
      "Type": "String",
      "Default": "0wv2nyk3je"
    },
    "EcsClusterName": {
      "Type": "String",
      "Default": "terraai-cluster"
    },
    "EcsServiceName": {
      "Type": "String",
      "Default": "terraai-api"
    }
  },
  "Resources": {
    "LambdaErrorsAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-LambdaErrors",
        "AlarmDescription": "Lambda errors exceeded threshold (>5 in 5 min)",
        "MetricName": "Errors",
        "Namespace": "AWS/Lambda",
        "Dimensions": [
          { "Name": "FunctionName", "Value": { "Ref": "LambdaFunctionName" } }
        ],
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 5,
        "ComparisonOperator": "GreaterThanThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }],
        "OKActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "LambdaDurationAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-LambdaDuration",
        "AlarmDescription": "Lambda p99 duration exceeded 3000ms",
        "MetricName": "Duration",
        "Namespace": "AWS/Lambda",
        "Dimensions": [
          { "Name": "FunctionName", "Value": { "Ref": "LambdaFunctionName" } }
        ],
        "ExtendedStatistic": "p99",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 3000,
        "ComparisonOperator": "GreaterThanThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "ApiGateway5xxAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-ApiGateway5xx",
        "AlarmDescription": "API Gateway 5xx error rate exceeded 1%",
        "Metrics": [
          {
            "Id": "errors5xx",
            "MetricStat": {
              "Metric": {
                "Namespace": "AWS/ApiGateway",
                "MetricName": "5XXError",
                "Dimensions": [{ "Name": "ApiId", "Value": { "Ref": "ApiGatewayId" } }]
              },
              "Period": 300,
              "Stat": "Sum"
            },
            "ReturnData": false
          },
          {
            "Id": "totalRequests",
            "MetricStat": {
              "Metric": {
                "Namespace": "AWS/ApiGateway",
                "MetricName": "Count",
                "Dimensions": [{ "Name": "ApiId", "Value": { "Ref": "ApiGatewayId" } }]
              },
              "Period": 300,
              "Stat": "Sum"
            },
            "ReturnData": false
          },
          {
            "Id": "errorRate",
            "Expression": "errors5xx / totalRequests * 100",
            "ReturnData": true
          }
        ],
        "ComparisonOperator": "GreaterThanThreshold",
        "Threshold": 1,
        "EvaluationPeriods": 1,
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "ApiGateway4xxAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-ApiGateway4xx",
        "AlarmDescription": "API Gateway 4xx error rate exceeded 10%",
        "Metrics": [
          {
            "Id": "errors4xx",
            "MetricStat": {
              "Metric": {
                "Namespace": "AWS/ApiGateway",
                "MetricName": "4XXError",
                "Dimensions": [{ "Name": "ApiId", "Value": { "Ref": "ApiGatewayId" } }]
              },
              "Period": 300,
              "Stat": "Sum"
            },
            "ReturnData": false
          },
          {
            "Id": "total4xx",
            "MetricStat": {
              "Metric": {
                "Namespace": "AWS/ApiGateway",
                "MetricName": "Count",
                "Dimensions": [{ "Name": "ApiId", "Value": { "Ref": "ApiGatewayId" } }]
              },
              "Period": 300,
              "Stat": "Sum"
            },
            "ReturnData": false
          },
          {
            "Id": "rate4xx",
            "Expression": "errors4xx / total4xx * 100",
            "ReturnData": true
          }
        ],
        "ComparisonOperator": "GreaterThanThreshold",
        "Threshold": 10,
        "EvaluationPeriods": 1,
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "DynamoDBThrottleAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-DynamoDBThrottle",
        "AlarmDescription": "DynamoDB throttled requests exceeded 10",
        "MetricName": "ThrottledRequests",
        "Namespace": "AWS/DynamoDB",
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 10,
        "ComparisonOperator": "GreaterThanThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "ECSHighCPUAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-ECSHighCPU",
        "AlarmDescription": "ECS service CPU utilization exceeded 80%",
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/ECS",
        "Dimensions": [
          { "Name": "ClusterName", "Value": { "Ref": "EcsClusterName" } },
          { "Name": "ServiceName", "Value": { "Ref": "EcsServiceName" } }
        ],
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "ECSHighMemoryAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": "OpusAIMobility-ECSHighMemory",
        "AlarmDescription": "ECS service memory utilization exceeded 80%",
        "MetricName": "MemoryUtilization",
        "Namespace": "AWS/ECS",
        "Dimensions": [
          { "Name": "ClusterName", "Value": { "Ref": "EcsClusterName" } },
          { "Name": "ServiceName", "Value": { "Ref": "EcsServiceName" } }
        ],
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [{ "Ref": "SnsTopicArn" }]
      }
    },
    "OpusAIMobilityDashboard": {
      "Type": "AWS::CloudWatch::Dashboard",
      "Properties": {
        "DashboardName": "OpusAIMobility-Dashboard",
        "DashboardBody": {
          "Fn::Sub": "{\"widgets\":[{\"type\":\"metric\",\"x\":0,\"y\":0,\"width\":12,\"height\":6,\"properties\":{\"title\":\"Lambda Invocations & Errors\",\"metrics\":[[\"AWS/Lambda\",\"Invocations\",\"FunctionName\",\"${LambdaFunctionName}\"],[\"AWS/Lambda\",\"Errors\",\"FunctionName\",\"${LambdaFunctionName}\"]],\"period\":300,\"stat\":\"Sum\",\"view\":\"timeSeries\",\"region\":\"us-east-1\"}},{\"type\":\"metric\",\"x\":12,\"y\":0,\"width\":12,\"height\":6,\"properties\":{\"title\":\"API Gateway Requests & 5xx\",\"metrics\":[[\"AWS/ApiGateway\",\"Count\",\"ApiId\",\"${ApiGatewayId}\"],[\"AWS/ApiGateway\",\"5XXError\",\"ApiId\",\"${ApiGatewayId}\"],[\"AWS/ApiGateway\",\"4XXError\",\"ApiId\",\"${ApiGatewayId}\"]],\"period\":300,\"stat\":\"Sum\",\"view\":\"timeSeries\",\"region\":\"us-east-1\"}},{\"type\":\"metric\",\"x\":0,\"y\":6,\"width\":12,\"height\":6,\"properties\":{\"title\":\"DynamoDB Read/Write Capacity\",\"metrics\":[[\"AWS/DynamoDB\",\"ConsumedReadCapacityUnits\"],[\"AWS/DynamoDB\",\"ConsumedWriteCapacityUnits\"],[\"AWS/DynamoDB\",\"ThrottledRequests\"]],\"period\":300,\"stat\":\"Sum\",\"view\":\"timeSeries\",\"region\":\"us-east-1\"}},{\"type\":\"metric\",\"x\":12,\"y\":6,\"width\":12,\"height\":6,\"properties\":{\"title\":\"ECS CPU & Memory\",\"metrics\":[[\"AWS/ECS\",\"CPUUtilization\",\"ClusterName\",\"${EcsClusterName}\",\"ServiceName\",\"${EcsServiceName}\"],[\"AWS/ECS\",\"MemoryUtilization\",\"ClusterName\",\"${EcsClusterName}\",\"ServiceName\",\"${EcsServiceName}\"]],\"period\":300,\"stat\":\"Average\",\"view\":\"timeSeries\",\"region\":\"us-east-1\"}}]}"
        }
      }
    }
  },
  "Outputs": {
    "DashboardUrl": {
      "Description": "CloudWatch Dashboard URL",
      "Value": {
        "Fn::Sub": "https://console.aws.amazon.com/cloudwatch/home?region=us-east-1#dashboards:name=OpusAIMobility-Dashboard"
      }
    }
  }
}
