{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GoGrabDynamoDBAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchWriteItem",
        "dynamodb:BatchGetItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-users",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-users/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurants",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurants/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurant-menus",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurant-menus/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurant-menu-items",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-restaurant-menu-items/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-food-orders",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-food-orders/index/*",
