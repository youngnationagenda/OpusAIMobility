        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-parcel-orders/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-trips",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-trips/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-requests",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-requests/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-vehicles",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-vehicles/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-vehicle-types",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-ride-types",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-coupons",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-coupons/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-food-categories",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-package-sizes",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-good-types",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-notifications",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-notifications/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-driver-ratings",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-driver-ratings/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-transactions",
