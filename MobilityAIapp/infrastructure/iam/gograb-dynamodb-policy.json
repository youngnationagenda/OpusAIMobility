        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-user-documents",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-user-documents/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-service-charges",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-html-pages",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-html-pages/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-withdraw-requests",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-withdraw-requests/index/*",
        "arn:aws:dynamodb:us-east-1:683541453923:table/gograb-app-config"
      ]
    },
    {
      "Sid": "GoGrabS3ImageUploads",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::aimobility-uploads-683541453923/gograb/*"
      ]
    }
  ]
