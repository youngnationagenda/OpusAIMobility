{
  "description": "Secrets Manager rotation configuration for OpusAIMobility secrets",
  "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
  "secrets": [
    {
      "secretId": "terraai/mpesa",
      "description": "M-Pesa Daraja API credentials (consumer key + secret + shortcode)",
      "rotationEnabled": true,
      "rotationIntervalDays": 90,
      "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
      "tags": { "service": "mpesa", "env": "production" }
    },
    {
      "secretId": "terraai/stripe",
      "description": "Stripe secret key (sk_live_...)",
      "rotationEnabled": true,
      "rotationIntervalDays": 90,
      "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
      "tags": { "service": "stripe", "env": "production" }
    },
    {
      "secretId": "terraai/fcm-server-key",
      "description": "Firebase Cloud Messaging server key for push notifications",
      "rotationEnabled": false,
      "rotationIntervalDays": null,
      "rotationLambdaArn": null,
      "note": "FCM keys are rotated manually via Firebase Console — auto-rotation not supported",
      "tags": { "service": "fcm", "env": "production" }
    },
    {
      "secretId": "terraai/airtel",
      "description": "Airtel Money API credentials",
      "rotationEnabled": true,
      "rotationIntervalDays": 90,
      "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
      "tags": { "service": "airtel", "env": "production" }
    },
    {
      "secretId": "terraai/tkash",
      "description": "T-Kash API credentials",
      "rotationEnabled": true,
      "rotationIntervalDays": 90,
      "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
      "tags": { "service": "tkash", "env": "production" }
    },
    {
      "secretId": "terraai/celo-contract",
      "description": "Celo blockchain private key and contract address for TerraCarbon token",
      "rotationEnabled": false,
      "rotationIntervalDays": null,
      "rotationLambdaArn": null,
      "note": "Blockchain private keys cannot be auto-rotated — requires manual key ceremony",
      "tags": { "service": "blockchain", "env": "production" }
    },
    {
      "secretId": "omniride/gemini-api-key",
      "description": "Google Gemini 2.0 Flash API key for AI features",
      "rotationEnabled": true,
      "rotationIntervalDays": 90,
      "rotationLambdaArn": "arn:aws:lambda:us-east-1:683541453923:function:terraai-secrets-rotation",
      "tags": { "service": "gemini", "env": "production" }
    }
  ],
  "monitoring": {
    "alertOnExpiry": true,
    "daysBeforeExpiry": 14,
    "snsTopicArn": "arn:aws:sns:us-east-1:683541453923:omniride-notifications",
    "description": "Send SNS alert 14 days before any secret expires"
  },
  "deployInstructions": {
    "enableRotation": "aws secretsmanager rotate-secret --secret-id <secretId> --rotation-lambda-arn <rotationLambdaArn> --rotation-rules AutomaticallyAfterDays=90",
    "checkStatus": "aws secretsmanager describe-secret --secret-id <secretId>",
    "manualRotate": "aws secretsmanager rotate-secret --secret-id <secretId> --rotate-immediately"
  }
}
