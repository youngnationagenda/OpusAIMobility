{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "OpusAIMobility RDS Network Isolation — private subnets, KMS, Multi-AZ",
  "Parameters": {
    "VpcId": {
      "Type": "AWS::EC2::VPC::Id",
      "Description": "VPC ID"
    },
    "RdsMasterPassword": {
      "Type": "String",
      "NoEcho": true,
      "Description": "RDS master password (stored in Secrets Manager)"
    },
    "RdsSGId": {
      "Type": "String",
      "Description": "RDS Security Group ID (from security-groups.json output)"
    }
  },
  "Resources": {
    "RdsKmsKey": {
      "Type": "AWS::KMS::Key",
      "Properties": {
        "Description": "KMS key for RDS encryption — OpusAIMobility",
        "EnableKeyRotation": true,
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": { "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" } },
              "Action": "kms:*",
              "Resource": "*"
            },
            {
              "Effect": "Allow",
              "Principal": { "Service": "rds.amazonaws.com" },
              "Action": ["kms:Decrypt", "kms:GenerateDataKey"],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "RdsKmsAlias": {
      "Type": "AWS::KMS::Alias",
      "Properties": {
        "AliasName": "alias/opusaimobility-rds",
        "TargetKeyId": { "Ref": "RdsKmsKey" }
      }
    },
    "PrivateSubnet1": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": { "Ref": "VpcId" },
        "CidrBlock": "10.0.3.0/24",
        "AvailabilityZone": "us-east-1a",
        "MapPublicIpOnLaunch": false,
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-rds-private-1a" }]
      }
    },
    "PrivateSubnet2": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": { "Ref": "VpcId" },
        "CidrBlock": "10.0.4.0/24",
        "AvailabilityZone": "us-east-1b",
        "MapPublicIpOnLaunch": false,
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-rds-private-1b" }]
      }
    },
    "RdsSubnetGroup": {
      "Type": "AWS::RDS::DBSubnetGroup",
      "Properties": {
        "DBSubnetGroupDescription": "Private subnets for OpusAIMobility RDS — us-east-1a and us-east-1b",
        "SubnetIds": [{ "Ref": "PrivateSubnet1" }, { "Ref": "PrivateSubnet2" }],
        "Tags": [{ "Key": "Name", "Value": "opusaimobility-rds-subnet-group" }]
      }
    },
    "RdsParameterGroup": {
      "Type": "AWS::RDS::DBParameterGroup",
      "Properties": {
        "Family": "mysql8.0",
        "Description": "OpusAIMobility MySQL 8.0 — TLS enforced",
        "Parameters": {
          "require_secure_transport": "ON",
          "slow_query_log": "1",
          "long_query_time": "2",
          "innodb_buffer_pool_size": "{DBInstanceClassMemory*3/4}"
        }
      }
    },
    "RdsInstance": {
      "Type": "AWS::RDS::DBInstance",
      "DeletionPolicy": "Snapshot",
      "Properties": {
        "DBInstanceIdentifier": "opusaimobility-db",
        "DBInstanceClass": "db.t3.medium",
        "Engine": "mysql",
        "EngineVersion": "8.0",
        "MasterUsername": "terraai_admin",
        "MasterUserPassword": { "Ref": "RdsMasterPassword" },
        "DBName": "terraai",
        "MultiAZ": true,
        "StorageType": "gp3",
        "AllocatedStorage": "100",
        "MaxAllocatedStorage": 1000,
        "StorageEncrypted": true,
        "KmsKeyId": { "Ref": "RdsKmsKey" },
        "DBSubnetGroupName": { "Ref": "RdsSubnetGroup" },
        "DBParameterGroupName": { "Ref": "RdsParameterGroup" },
        "VPCSecurityGroups": [{ "Ref": "RdsSGId" }],
        "BackupRetentionPeriod": 7,
        "PreferredBackupWindow": "03:00-04:00",
        "PreferredMaintenanceWindow": "sun:04:00-sun:05:00",
        "DeletionProtection": true,
        "EnablePerformanceInsights": true,
        "MonitoringInterval": 60,
        "AutoMinorVersionUpgrade": true,
        "CopyTagsToSnapshot": true,
        "Tags": [
          { "Key": "Name", "Value": "opusaimobility-db" },
          { "Key": "Environment", "Value": "production" }
        ]
      }
    }
  },
  "Outputs": {
    "RdsEndpoint": {
      "Description": "RDS instance endpoint",
      "Value": { "Fn::GetAtt": ["RdsInstance", "Endpoint.Address"] }
    },
    "RdsPort": {
      "Description": "RDS instance port",
      "Value": { "Fn::GetAtt": ["RdsInstance", "Endpoint.Port"] }
    },
    "KmsKeyArn": {
      "Description": "KMS key ARN for RDS encryption",
      "Value": { "Fn::GetAtt": ["RdsKmsKey", "Arn"] }
    }
  }
}
