# ─────────────────────────────────────────────────────────────────
# OpusAIMobility — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment & Secrets (NEVER commit these) ────────────────────
.env
.env.*
.env.local
.env.production
*.env

# ── Service Account Keys & Credentials ────────────────────────────
*-service-account.json
opusaimobility-*.json
*-d90412e*.json
*.p12
*.pem
*.key
*.jks
keystore.b64
keystore-meta.json

# ── API Keys & Tokens ─────────────────────────────────────────────
.gcp-token
*.token
*_token.json

# ── Sensitive text files that may contain secrets ─────────────────
Untitled.txt
tmp_section.txt
out.json

# ── AWS ───────────────────────────────────────────────────────────
*.zip
aws/lambda/*.zip
aws/*.zip

# ── Build outputs ─────────────────────────────────────────────────
dist/
build/
*.apk

# ── IDE & OS ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# ── Claude/Kiro internals ─────────────────────────────────────────
TerraAI/.claude/

# ── Terraform / IaC state ─────────────────────────────────────────
*.tfstate
*.tfstate.backup
.terraform/

# ── Test & debug response files ───────────────────────────────────
response_*.json
celo_logs_raw.json
test-*.json
health-response.json

# ── Scratch / one-off scripts ──────────────────────────────────────
_*.js
_*.sh

# ── CodeBuild sandbox session files ───────────────────────────────
codebuild-sandbox-key
codebuild-sandbox-key.pub
codebuild-ssh-config
connect-sandbox.bat
sandbox-*.sh
set-github-secrets.py
patch-cf.py
check_all.py
cf-e18-config.json
cf-e18-update.json
smoke-*.json
*-deploy.zip

# ── Logs ──────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Package locks (keep only root) ────────────────────────────────
# package-lock.json is tracked at root; ignore nested ones from Lambda deploys
aws/lambda/*/package-lock.json
server/package-lock.json
