# TERRA-030: Celo Deployment Environment
# Copy to .env.deploy and fill in real values
# NEVER commit .env.deploy to git

# Your deployer wallet private key (funded with CELO for gas)
# Get test CELO: https://faucet.celo.org/alfajores
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# CeloScan API key for contract verification
# Get from: https://celoscan.io/myapikey
CELOSCAN_API_KEY=YOUR_CELOSCAN_API_KEY
