<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- AnchorBottomSheetBehavior -->
    <declare-styleable name="AnchorBottomSheetBehavior_Layout">
        <attr name="behavior_anchorOffset" format="dimension" />
        <attr name="behavior_defaultState" format="enum">
            <enum name="expanded" value="3" />
            <enum name="collapsed" value="4" />
            <enum name="hidden" value="5" />
            <enum name="anchored" value="6" />
        </attr>
        <attr name="behavior_skipAnchored" format="boolean" />
    </declare-styleable>

    <!-- LoadingButton -->
    <declare-styleable name="LoadingButton">
        <attr name="text" format="string" localization="suggested" />
        <attr name="textColor" format="color" />
        <attr name="backgroundColor" format="color"/>
        <attr name="background" format="reference"/>
        <attr name="textSize" format="dimension"/>
        <attr name="progressColor" format="color"/>
    </declare-styleable>

    <!-- ── Fresco SimpleDraweeView stubs ─────────────────────────────────── -->
    <declare-styleable name="GenericDraweeHierarchy">
        <attr name="actualImageScaleType" format="enum">
            <enum name="center" value="4"/>
            <enum name="centerCrop" value="5"/>
            <enum name="centerInside" value="6"/>
            <enum name="fitCenter" value="7"/>
            <enum name="fitEnd" value="8"/>
            <enum name="fitStart" value="9"/>
            <enum name="fitXY" value="10"/>
            <enum name="focusCrop" value="11"/>
        </attr>
        <attr name="placeholderImageScaleType" format="enum">
            <enum name="center" value="4"/>
            <enum name="centerCrop" value="5"/>
            <enum name="centerInside" value="6"/>
            <enum name="fitCenter" value="7"/>
            <enum name="fitEnd" value="8"/>
            <enum name="fitStart" value="9"/>
            <enum name="fitXY" value="10"/>
            <enum name="focusCrop" value="11"/>
        </attr>
        <attr name="placeholderImage" format="reference|color" />
        <attr name="failureImage" format="reference|color" />
        <attr name="failureImageScaleType" format="enum">
            <enum name="fitCenter" value="7"/>
        </attr>
        <attr name="retryImage" format="reference|color" />
        <attr name="retryImageScaleType" format="enum">
            <enum name="fitCenter" value="7"/>
        </attr>
        <attr name="progressBarImage" format="reference|color" />
        <attr name="progressBarImageScaleType" format="enum">
            <enum name="fitCenter" value="7"/>
        </attr>
        <attr name="progressBarAutoRotateInterval" format="integer" />
        <attr name="backgroundImage" format="reference|color" />
        <attr name="overlayImage" format="reference|color" />
        <attr name="pressedStateOverlayImage" format="reference|color" />
        <attr name="roundAsCircle" format="boolean" />
        <attr name="roundedCornerRadius" format="dimension" />
        <attr name="roundTopLeft" format="boolean" />
        <attr name="roundTopRight" format="boolean" />
        <attr name="roundBottomLeft" format="boolean" />
        <attr name="roundBottomRight" format="boolean" />
        <attr name="roundWithOverlayColor" format="color" />
        <attr name="roundingBorderWidth" format="dimension" />
        <attr name="roundingBorderColor" format="color" />
        <attr name="roundingBorderPadding" format="dimension" />
        <attr name="fadeDuration" format="integer" />
        <attr name="viewAspectRatio" format="float" />
    </declare-styleable>

    <!-- ── singledateandtimepicker stubs ──────────────────────────────────── -->
    <declare-styleable name="SingleDateAndTimePicker">
        <attr name="picker_curved" format="boolean" />
        <attr name="picker_cyclic" format="boolean" />
        <attr name="picker_visibleItemCount" format="integer" />
        <attr name="picker_selectedTextColor" format="color" />
        <attr name="picker_textSize" format="dimension" />
        <attr name="picker_itemSpacing" format="dimension" />
        <attr name="picker_displayDays" format="boolean" />
        <attr name="picker_displayDaysOfMonth" format="boolean" />
        <attr name="picker_displayMonth" format="boolean" />
        <attr name="picker_displayHours" format="boolean" />
