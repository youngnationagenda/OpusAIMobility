{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "VisualEditor0",
      "Effect": "Allow",
      "Action": "amplifybackend:*",
      "Resource": "*"
    },
    {
      "Sid": "PinpointPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::683541453923:role/aimobility-pinpoint-role",
      "Condition": {
        "StringLike": {
          "iam:PassedToService": "pinpoint.amazonaws.com"
        }
      }
    }
  ]
}
