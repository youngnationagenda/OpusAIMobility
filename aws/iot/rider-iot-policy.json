{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ConnectAsRider",
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:us-east-1:683541453923:client/opusaimobility-${iot:ClientId}"
    },
    {
      "Sid": "PublishTelemetry",
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": [
        "arn:aws:iot:us-east-1:683541453923:topic/opusaimobility/telemetry/${iot:ClientId}",
        "arn:aws:iot:us-east-1:683541453923:topic/opusaimobility/location/${iot:ClientId}"
      ]
    },
    {
      "Sid": "SubscribeNotifications",
      "Effect": "Allow",
      "Action": ["iot:Subscribe", "iot:Receive"],
      "Resource": [
        "arn:aws:iot:us-east-1:683541453923:topicfilter/opusaimobility/notifications/${iot:ClientId}",
        "arn:aws:iot:us-east-1:683541453923:topicfilter/opusaimobility/commands/${iot:ClientId}"
      ]
    },
    {
      "Sid": "GetThingShadow",
      "Effect": "Allow",
      "Action": ["iot:GetThingShadow", "iot:UpdateThingShadow"],
      "Resource": "arn:aws:iot:us-east-1:683541453923:thing/opusaimobility-rider-*"
    }
  ]
}
